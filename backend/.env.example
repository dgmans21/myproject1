# 복사 후 사용 (Windows)
#   copy .env.example .env
# macOS/Linux
#   cp .env.example .env
#
# Supabase Dashboard → Project Settings → API

SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_KEY=
SUPABASE_JWT_SECRET=

# Kakao Developers → REST API 키 (백엔드 이동시간 Mobility)
KAKAO_REST_API_KEY=

# 쉼표로 여러 origin 가능
CORS_ORIGINS=http://localhost:3000
